# Copy to .env on the server. Compose reads it automatically.
# Leave GROUP_ID empty on first run, read the JID from the logs, then set it.
GROUP_ID=
TZ=Europe/Berlin
SEASON_START=2026-01-01
# Scheduled group digests. Both OFF by default so nothing posts until you opt in.
# Flip to true to enable; you can preview/post on demand via /admin/summary regardless.
DAILY_SUMMARY=false
WEEKLY_SUMMARY=false
WEEKLY_CRON=5 0 * * 1
# If set, required as ?token= on /admin/summary. Leave empty for an unguarded endpoint.
ADMIN_TOKEN=
