# Copy to .env on the server. Compose reads it automatically.
# Leave GROUP_ID empty on first run, read the JID from the logs, then set it.
GROUP_ID=
TZ=Europe/Berlin
SEASON_START=2026-01-01
# Scheduled group digests: starting state. Toggle live at /summary (persists to
# data/settings.json, which then overrides these on restart).
DAILY_SUMMARY=false
WEEKLY_SUMMARY=false
WEEKLY_CRON=5 0 * * 1
# Admin password for /summary and /admin/summary (HTTP Basic Auth, any username).
# REQUIRED to enable those pages — leave empty and they return 503 (locked).
ADMIN_TOKEN=
